<Window x:Class="WpfApp1.Views.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="STOCK_TRANSFER_PROTOCOL" Height="300" Width="400"
        Background="#0D0D0D" WindowStartupLocation="CenterOwner" BorderBrush="Yellow" BorderThickness="2">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="TRANSFER_INITIATED" Foreground="Yellow" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="TARGET_WAREHOUSE:" Foreground="Cyan" Margin="0,5"/>
            <ComboBox x:Name="DestWarehouseCombo" DisplayMemberPath="Name" Background="#111" Foreground="White"/>

            <TextBlock Text="TRANSFER_QUANTITY:" Foreground="Cyan" Margin="0,15,0,5"/>
            <TextBox x:Name="QtyTextBox" Text="1" Background="#111" Foreground="White" BorderBrush="Cyan"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="CANCEL" Click="Cancel_Click" Style="{StaticResource CyberButton}" Margin="5" BorderBrush="Gray"/>
                <Button Content="EXECUTE_TRANSFER" Click="Transfer_Click" Style="{StaticResource CyberButton}" Margin="5" BorderBrush="Yellow" Foreground="Yellow"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>