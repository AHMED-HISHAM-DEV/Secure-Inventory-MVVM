<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp1.ViewModels"
        xmlns:views="clr-namespace:WpfApp1.Views"
        Title="CYBERSTOCK_OS // v2.0" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#05050A">

    <Window.DataContext>
        <vm:DashboardViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0A0A12" BorderBrush="#1A00FFFF" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="10,30,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" 
                              Fill="#00FFFF" Width="22" Height="22" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="CYBERSTOCK" Foreground="#00FFFF" FontSize="20" FontWeight="Bold" FontFamily="Consolas">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <Button Content="  DASHBOARD" Style="{StaticResource CyberButton}" Margin="5" Click="ShowDashboard" Tag="Active"/>
                    <Button Content="  INVENTORY" Style="{StaticResource CyberButton}" Margin="5" Click="ShowInventory"/>
                    <Button Content="  WAREHOUSES" Style="{StaticResource CyberButton}" Margin="5" Click="ShowWarehouses"/>
                    <Button Content="  USERS_MGMT" Style="{StaticResource CyberButton}" Margin="5" Click="ShowUsers"/>

                   
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Margin="20">
                    <TextBlock Text="OPERATOR: ADMIN_AHMED" Foreground="#6600FFFF" FontSize="10" FontFamily="Consolas"/>
                    <TextBlock Text="UPLINK: SECURE" Foreground="Lime" FontSize="9" Margin="0,5,0,0" FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#05050A" Offset="0"/>
                    <GradientStop Color="#0D1225" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <ContentControl x:Name="MainContent" Margin="10"/>
        </Grid>
    </Grid>
</Window>