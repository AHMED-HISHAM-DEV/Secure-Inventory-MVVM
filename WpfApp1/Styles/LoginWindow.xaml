<Window x:Class="WpfApp1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Authentication" Height="400" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="20" Background="#0D0D0D" BorderBrush="Cyan" BorderThickness="2">
        <StackPanel Margin="30">
            <TextBlock Text="ACCESS_RESTRICTED" Foreground="Red" HorizontalAlignment="Center" 
                       FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
            <TextBlock Text="CYBERSTOCK_OS" Foreground="Cyan" FontSize="26" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,10,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="10" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="OPERATOR_ID" Style="{StaticResource CyberText}" FontSize="10" Margin="0,10,0,5"/>
            <TextBox x:Name="TxtUser" Background="#111" Foreground="White" BorderBrush="Cyan" Padding="5"/>

            <TextBlock Text="ACCESS_KEY" Style="{StaticResource CyberText}" FontSize="10" Margin="0,15,0,5"/>
            <PasswordBox x:Name="TxtPass" Background="#111" Foreground="White" BorderBrush="Cyan" Padding="5"/>

            <Button Content="AUTHENTICATE" Margin="0,40,0,10" Style="{StaticResource CyberButton}" Click="BtnLogin_Click"/>
            <Button Content="TERMINATE_SESSION" Style="{StaticResource CyberButton}" BorderBrush="DimGray" Foreground="DimGray" Click="BtnExit_Click"/>
        </StackPanel>
    </Border>
</Window>